@page "/datatables"
@inject IJSRuntime JS

<PageTitle>DataTables Demo</PageTitle>

<div class="container-fluid py-4">
    <h1 class="mb-1">DataTables Demo</h1>
    <p class="text-muted mb-4">
        Demonstrating <strong>DataTables 2.x</strong> integrated with <strong>Bootstrap 5.3</strong>
        in a Blazor WebAssembly application. Columns are sortable, searchable, and paginated.
    </p>

    <div class="card shadow-sm">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0">Employee Directory</h5>
        </div>
        <div class="card-body dt-dark-header">
            <table id="employeeTable" class="table table-striped table-hover table-bordered align-middle" style="width:100%">
                <thead class="table-dark">
                    <tr>
                        <th scope="col">Name</th>
                        <th scope="col">Position</th>
                        <th scope="col">Department</th>
                        <th scope="col">Office</th>
                        <th scope="col">Age</th>
                        <th scope="col">Start Date</th>
                        <th scope="col">Salary</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var emp in Employees)
                    {
                        <tr>
                            <td>@emp.Name</td>
                            <td>@emp.Position</td>
                            <td>@emp.Department</td>
                            <td>@emp.Office</td>
                            <td>@emp.Age</td>
                            <td>@emp.StartDate.ToString("yyyy-MM-dd")</td>
                            <td>@emp.Salary.ToString("C0")</td>
                        </tr>
                    }
                </tbody>
                <tfoot>
                    <tr>
                        <th scope="col">Name</th>
                        <th scope="col">Position</th>
                        <th scope="col">Department</th>
                        <th scope="col">Office</th>
                        <th scope="col">Age</th>
                        <th scope="col">Start Date</th>
                        <th scope="col">Salary</th>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>
</div>

