@page "/datatables-light"
@inject IJSRuntime JS

<PageTitle>DataTables Light Theme Demo</PageTitle>

<div class="container-fluid py-4">
    <h1 class="mb-1">DataTables – Light Header Theme</h1>
    <p class="text-muted mb-4">
        Sort icons use <strong>black</strong> for unsorted columns,
        <span style="color:#0076ab;font-weight:600;">blue</span> for ascending, and
        <span style="color:#00c851;font-weight:600;">green</span> for descending — optimised for light header backgrounds.
    </p>

    <div class="card shadow-sm">
        <div class="card-header bg-light border-bottom">
            <h5 class="mb-0 text-dark">Product Catalog</h5>
        </div>
        <div class="card-body dt-light-header">
            <table id="productTable" class="table table-striped table-hover table-bordered align-middle" style="width:100%">
                <thead class="table-light">
                    <tr>
                        <th scope="col">Product</th>
                        <th scope="col">Category</th>
                        <th scope="col">Brand</th>
                        <th scope="col">SKU</th>
                        <th scope="col">Stock</th>
                        <th scope="col">Unit Price</th>
                        <th scope="col">Rating</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in Products)
                    {
                        <tr>
                            <td>@p.Name</td>
                            <td>@p.Category</td>
                            <td>@p.Brand</td>
                            <td>@p.SKU</td>
                            <td>@p.Stock</td>
                            <td>@p.UnitPrice.ToString("C2")</td>
                            <td>@p.Rating.ToString("F1")</td>
                        </tr>
                    }
                </tbody>
                <tfoot>
                    <tr>
                        <th scope="col">Product</th>
                        <th scope="col">Category</th>
                        <th scope="col">Brand</th>
                        <th scope="col">SKU</th>
                        <th scope="col">Stock</th>
                        <th scope="col">Unit Price</th>
                        <th scope="col">Rating</th>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>
</div>

